NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
APP_URL=http://localhost:3000
APP_ENV=development
# Protects /api/cron/punctuality — Vercel Cron sends this automatically as a
# Bearer token when set as a project env var. Leave unset locally to test
# the endpoint without a secret.
CRON_SECRET=
